# Copy this file to .env and adjust only what you need.
# The default path is fully local-first and WHO XML based.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EXTRACTION_MODEL=llama3.1:8b
OLLAMA_CODING_MODEL=llama3.1:8b
OLLAMA_EXPLANATION_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

CHROMA_PERSIST_DIR=./data/chroma_db
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

REASONING_MODE=local
REASONING_PROVIDER=ollama
REASONING_MODEL=
CLOUD_ALLOWED_TASKS=extract,coding,explain
DEIDENTIFY_REQUIRED_FOR_CLOUD=true
SEND_RAW_NOTES=false

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

HIGH_CONFIDENCE_THRESHOLD=0.80
LOW_CONFIDENCE_THRESHOLD=0.50

TERMINOLOGY_SOURCE=who_icd10_2019
TERMINOLOGY_EDITION=WHO ICD-10 2019
ICD10_CODE_LIST_PATH=./config/code_lists/icd102019en.xml
VALIDATION_RULES_PATH=./config/code_lists/validation_rules.json

AUDIT_LOG_PATH=data/audit.log
DEBUG_LOG_PROMPTS=false
